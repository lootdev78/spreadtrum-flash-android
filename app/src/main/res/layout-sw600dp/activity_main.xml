<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="horizontal">

    <com.google.android.material.navigationrail.NavigationRailView
        android:id="@+id/bottomNavigation"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:background="@color/surface"
        android:paddingTop="12dp"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bottom"
        app:menuGravity="center" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:elevation="0dp"
            android:minHeight="64dp"
            android:paddingHorizontal="16dp"
            app:subtitle="libusb · Android USB Host"
            app:title="SPRD Flash Studio"
            app:titleTextAppearance="?attr/textAppearanceTitleLarge" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SpdFlash.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/surface_container">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/statusDot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/status_dot_off" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/globalStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="1"
                            android:text="No device connected"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/globalDetail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Select a USB device, then connect"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/stageChip"
                        style="@style/Widget.Material3.Chip.Assist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checkable="false"
                        android:text="Disconnected" />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/globalProgress"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="12dp"
                    android:max="100"
                    android:progress="0"
                    android:visibility="gone"
                    app:trackCornerRadius="2dp" />

                <TextView
                    android:id="@+id/progressText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="end"
                    android:textAppearance="@style/TextAppearance.SpdFlash.Mono"
                    android:textColor="@color/on_surface_variant"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:id="@+id/screenContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="8dp">

            <include android:id="@+id/screenDashboard" layout="@layout/screen_dashboard" />
            <include android:id="@+id/screenLoaders" layout="@layout/screen_loaders" android:visibility="gone" />
            <include android:id="@+id/screenCommands" layout="@layout/screen_commands" android:visibility="gone" />
            <include android:id="@+id/screenQueue" layout="@layout/screen_queue" android:visibility="gone" />
            <include android:id="@+id/screenConsole" layout="@layout/screen_console" android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
