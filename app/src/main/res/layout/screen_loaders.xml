<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loader pipeline"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="FDL files are imported into private app storage, hashed, and loaded before the operation queue."
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/on_surface_variant" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/useLoadersCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:checked="true"
            android:text="Load FDL1 and FDL2 automatically" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SpdFlash.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="FDL1"
                        android:src="@drawable/ic_loader"
                        app:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="FDL1 / SPL Loader"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Boot-ROM → FDL1"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/fdl1Path"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:ellipsize="middle"
                    android:fontFamily="monospace"
                    android:maxLines="2"
                    android:text="No file selected"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textIsSelectable="true" />

                <TextView
                    android:id="@+id/fdl1Metadata"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Size and SHA-256 are shown after selection"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/on_surface_variant" />

                <TextView
                    android:id="@+id/fdl1Hash"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="middle"
                    android:fontFamily="monospace"
                    android:maxLines="1"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/on_surface_variant"
                    android:textIsSelectable="true" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/fdl1AddressLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="FDL1 load address"
                    app:helperText="Example: 0x5500 or 0x65000800">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/fdl1AddressInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:inputType="textNoSuggestions" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/selectFdl1Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select FDL1"
                    app:icon="@drawable/ic_file" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SpdFlash.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="FDL2"
                        android:src="@drawable/ic_loader"
                        app:tint="@color/secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="FDL2 / U-Boot / LK"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="FDL1 → FDL2"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/fdl2Path"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:ellipsize="middle"
                    android:fontFamily="monospace"
                    android:maxLines="2"
                    android:text="No file selected"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textIsSelectable="true" />

                <TextView
                    android:id="@+id/fdl2Metadata"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Size and SHA-256 are shown after selection"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/on_surface_variant" />

                <TextView
                    android:id="@+id/fdl2Hash"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="middle"
                    android:fontFamily="monospace"
                    android:maxLines="1"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/on_surface_variant"
                    android:textIsSelectable="true" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/fdl2AddressLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="FDL2 load address"
                    app:helperText="The address is device-specific">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/fdl2AddressInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:inputType="textNoSuggestions" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/selectFdl2Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select FDL2"
                    app:icon="@drawable/ic_file" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/executeFdl2Check"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:checked="true"
            android:text="Execute FDL2 after upload (exec)" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SpdFlash.Card.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="The app cannot guarantee FDL compatibility from the filename alone. Compare the chip, storage type, and load addresses with a verified firmware source."
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/on_surface_variant" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
